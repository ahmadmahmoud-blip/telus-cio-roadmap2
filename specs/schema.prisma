// Prisma Schema — Org Roadmap Tool
// Database: PostgreSQL
// ORM: Prisma 5.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum ItemStatus {
  Discovery
  Planned
  InProgress  @map("In Progress")
  Shipped
  Blocked
  Cancelled
}

enum ItemPriority {
  P0
  P1
  P2
  P3
}

enum ConfidenceLevel {
  High
  Medium
  Low
  TBD
}

enum UserRole {
  admin
  editor
  viewer
}

enum AuditAction {
  created
  updated
  archived
}

enum SyncInterval {
  min15   @map("15min")
  hr1     @map("1hr")
  hr4     @map("4hr")
  manual
}

enum ExportSchedule {
  disabled
  daily
  weekly
}

enum NotificationType {
  item_updated
  item_assigned
  jira_sync_error
  sheets_export_complete
}

enum JobStatus {
  queued
  running
  completed
  failed
}

// ─────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String
  avatarUrl   String?
  role        UserRole  @default(viewer)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  squadMemberships  UserSquad[]
  itemsCreated      RoadmapItem[] @relation("CreatedBy")
  itemsUpdated      RoadmapItem[] @relation("UpdatedBy")
  auditActions      AuditLog[]
  notifications     Notification[]
  filterPresets     FilterPreset[]
  leadOfSquads      Squad[]       @relation("SquadLead")
  invitations       Invitation[]

  @@index([email])
  @@index([role])
}

// Many-to-many: users <-> squads (for editors)
model UserSquad {
  userId    String
  squadId   String
  assignedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@id([userId, squadId])
  @@index([squadId])
}

model Invitation {
  id         String    @id @default(cuid())
  email      String
  role       UserRole
  squadIds   String[]  // stored as array, resolved on acceptance
  invitedBy  String
  token      String    @unique @default(cuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  invitedByUser User @relation(fields: [invitedBy], references: [id])

  @@index([email])
  @@index([token])
}

// ─────────────────────────────────────────────
// Org Structure
// ─────────────────────────────────────────────

model ProductArea {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  squads Squad[]
  items  RoadmapItem[]
}

model Squad {
  id            String   @id @default(cuid())
  name          String   @unique
  color         String   @default("#8b5cf6")
  productAreaId String?
  leadUserId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  productArea ProductArea?  @relation(fields: [productAreaId], references: [id], onDelete: SetNull)
  lead        User?         @relation("SquadLead", fields: [leadUserId], references: [id], onDelete: SetNull)
  members     UserSquad[]
  items       RoadmapItem[]

  @@index([productAreaId])
}

// ─────────────────────────────────────────────
// Roadmap Items
// ─────────────────────────────────────────────

model RoadmapItem {
  id                  String          @id @default(cuid())
  title               String
  description         String?         @db.Text
  squadId             String
  productAreaId       String
  status              ItemStatus      @default(Discovery)
  priority            ItemPriority    @default(P2)
  targetQuarterStart  String          // "2025-Q1"
  targetQuarterEnd    String          // "2025-Q3"
  confidence          ConfidenceLevel @default(TBD)
  labels              String[]        @default([])
  createdById         String
  updatedById         String
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  archivedAt          DateTime?

  // Relations
  squad       Squad       @relation(fields: [squadId], references: [id])
  productArea ProductArea @relation(fields: [productAreaId], references: [id])
  createdBy   User        @relation("CreatedBy", fields: [createdById], references: [id])
  updatedBy   User        @relation("UpdatedBy", fields: [updatedById], references: [id])
  jiraLinks   JiraLink[]
  auditLogs   AuditLog[]
  notifications Notification[]

  @@index([squadId])
  @@index([productAreaId])
  @@index([status])
  @@index([priority])
  @@index([targetQuarterStart])
  @@index([targetQuarterEnd])
  @@index([archivedAt])
  @@index([updatedAt])
  // Full-text search index (PostgreSQL)
  @@index([title], type: BTree)
}

// ─────────────────────────────────────────────
// Jira Integration
// ─────────────────────────────────────────────

model JiraLink {
  id          String    @id @default(cuid())
  itemId      String
  jiraKey     String               // "PROJ-123"
  summary     String?
  jiraStatus  String?
  jiraUrl     String?
  type        String    @default("issue")  // "epic" | "issue"
  lastSyncedAt DateTime?
  syncError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  item RoadmapItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, jiraKey])
  @@index([itemId])
  @@index([jiraKey])
}

// Org-level Jira integration config (singleton per org, enforced in app layer)
model JiraIntegration {
  id            String       @id @default(cuid())
  jiraBaseUrl   String?      // null for Jira Cloud
  jiraAccountId String?      // Jira user account ID
  jiraUserName  String?      // Display name for UI
  accessToken   String       @db.Text   // encrypted
  refreshToken  String?      @db.Text   // encrypted
  tokenExpiresAt DateTime?
  syncInterval  SyncInterval @default(hr1)
  lastSyncAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ─────────────────────────────────────────────
// Google Sheets Integration
// ─────────────────────────────────────────────

model GoogleIntegration {
  id              String         @id @default(cuid())
  googleEmail     String?
  accessToken     String         @db.Text   // encrypted
  refreshToken    String?        @db.Text   // encrypted
  tokenExpiresAt  DateTime?
  spreadsheetId   String?
  spreadsheetUrl  String?
  sheetTabName    String?        @default("Roadmap")
  schedule        ExportSchedule @default(disabled)
  lastExportAt    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Async job tracking for export/import
model IntegrationJob {
  id                  String    @id @default(cuid())
  type                String    // "jira_sync" | "sheets_export" | "sheets_import"
  status              JobStatus @default(queued)
  payload             Json?     // input params (e.g. spreadsheetId for import)
  result              Json?     // output (rowCount, errors, etc.)
  error               String?   @db.Text
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([type, status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Audit Log
// ─────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  entityType   String      // "RoadmapItem" | "Squad" | "ProductArea" | "User"
  entityId     String
  entityTitle  String?     // denormalized snapshot of title at time of event
  action       AuditAction
  changedById  String
  diff         Json        // { field: { before: x, after: y } }
  timestamp    DateTime    @default(now())

  changedBy    User         @relation(fields: [changedById], references: [id])
  item         RoadmapItem? @relation(fields: [entityId], references: [id], map: "AuditLog_itemId_fkey")

  @@index([entityType, entityId])
  @@index([changedById])
  @@index([timestamp])
}

// ─────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType
  message     String
  entityId    String?
  entityType  String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  item RoadmapItem? @relation(fields: [entityId], references: [id], map: "Notification_itemId_fkey")

  @@index([userId, readAt])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// Filter Presets
// ─────────────────────────────────────────────

model FilterPreset {
  id          String   @id @default(cuid())
  name        String
  filters     Json     // FilterState shape from api.ts
  isShared    Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([isShared])
}
